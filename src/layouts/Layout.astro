---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth" data-theme="dark" data-language="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Julio Otero — Frontend Developer. Portafolio de desarrollo web."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>

  <body class="bg-grid bg-noise overflow-x-hidden">
    <div
      class="orb orb-green fixed w-[600px] h-[600px] -top-48 -left-48 opacity-60 pointer-events-none"
      style="z-index:0;"
    >
    </div>
    <div
      class="orb orb-blue fixed w-[500px] h-[500px] -bottom-32 -right-32 opacity-50 pointer-events-none"
      style="z-index:0;"
    >
    </div>

    <nav
      id="navbar"
      class="fixed top-0 w-full z-50 transition-all duration-300"
      style="background: transparent;"
    >
      <div class="max-w-6xl mx-auto px-6 lg:px-8">
        <div
          class="flex justify-between items-center h-14 border-b border-transparent transition-all duration-300"
          id="nav-inner"
        >
          <a href="#" class="flex items-center gap-2 group no-select">
            <span class="text-accent font-mono text-sm font-semibold">~/</span>
            <span
              class="font-display font-bold text-sm tracking-wide"
              style="color: var(--text-primary);">julio_otero</span
            >
            <span class="text-accent font-mono text-sm animate-pulse">▮</span>
          </a>

          <div class="hidden md:flex items-center gap-6">
            <a href="#about" class="nav-link" data-lang="es">sobre_mí</a>
            <a href="#about" class="nav-link" data-lang="en">about</a>

            <a href="#projects" class="nav-link" data-lang="es">proyectos</a>
            <a href="#projects" class="nav-link" data-lang="en">projects</a>

            <a href="#skills" class="nav-link" data-lang="es">skills</a>
            <a href="#skills" class="nav-link" data-lang="en">skills</a>

            <a href="#contact" class="nav-link" data-lang="es">contacto</a>
            <a href="#contact" class="nav-link" data-lang="en">contact</a>

            <span class="text-accent font-mono opacity-30">|</span>

            <div class="lang-toggle" id="lang-toggle">
              <button class="lang-btn active" data-lang-btn="es">ES</button>
              <button class="lang-btn" data-lang-btn="en">EN</button>
            </div>
          </div>

          <div class="flex md:hidden items-center gap-3">
            <div class="lang-toggle" id="lang-toggle-mobile">
              <button class="lang-btn active" data-lang-btn="es">ES</button>
              <button class="lang-btn" data-lang-btn="en">EN</button>
            </div>
            <button
              id="mobile-menu-btn"
              class="w-9 h-9 flex items-center justify-center panel"
              aria-label="Menu"
              style="color: var(--text-primary);"
            >
              <svg
                id="hamburger-icon"
                class="w-4 h-4"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <svg
                id="close-icon"
                class="w-4 h-4 hidden"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>

      <div
        id="mobile-menu"
        class="hidden md:hidden border-t"
        style="background: var(--bg-surface); border-color: var(--border);"
      >
        <div class="max-w-6xl mx-auto px-6 py-4 flex flex-col gap-1">
          <a href="#about" class="nav-link block py-2" data-lang="es"
            >sobre_mí</a
          >
          <a href="#about" class="nav-link block py-2" data-lang="en">about</a>
          <a href="#projects" class="nav-link block py-2" data-lang="es"
            >proyectos</a
          >
          <a href="#projects" class="nav-link block py-2" data-lang="en"
            >projects</a
          >
          <a href="#skills" class="nav-link block py-2">skills</a>
          <a href="#contact" class="nav-link block py-2" data-lang="es"
            >contacto</a
          >
          <a href="#contact" class="nav-link block py-2" data-lang="en"
            >contact</a
          >
        </div>
      </div>
    </nav>

    <div class="relative z-10">
      <slot />
    </div>

    <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
      <svg id="sun-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
        ></path>
      </svg>
      <svg
        id="moon-icon"
        class="hidden"
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
        ></path>
      </svg>
    </button>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add("visible");
          });
        },
        { threshold: 0.15, rootMargin: "0px 0px -10% 0px" },
      );

      function applyTheme(theme: string) {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);
        const sunIcon = document.getElementById("sun-icon");
        const moonIcon = document.getElementById("moon-icon");
        if (theme === "light") {
          sunIcon?.classList.add("hidden");
          moonIcon?.classList.remove("hidden");
        } else {
          sunIcon?.classList.remove("hidden");
          moonIcon?.classList.add("hidden");
        }
      }

      function applyLanguage(lang: string) {
        document.documentElement.setAttribute("data-language", lang);
        localStorage.setItem("language", lang);

        document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
          const b = btn as HTMLButtonElement;
          if (b.dataset.langBtn === lang) {
            b.classList.add("active");
          } else {
            b.classList.remove("active");
          }
        });
      }

      function handleNavbarScroll() {
        const navbar = document.getElementById("navbar");
        const navInner = document.getElementById("nav-inner");
        if (!navbar || !navInner) return;

        if (window.scrollY > 40) {
          navbar.style.background = "var(--bg-surface)";
          navbar.style.borderBottom = "1px solid var(--border)";
          navbar.style.boxShadow = "0 4px 24px var(--shadow)";
          navInner.style.borderBottomColor = "transparent";
        } else {
          navbar.style.background = "transparent";
          navbar.style.borderBottom = "none";
          navbar.style.boxShadow = "none";
        }
      }

      document.addEventListener("DOMContentLoaded", () => {
        document
          .querySelectorAll(".fade-in, .fade-in-left, .fade-in-right")
          .forEach((el) => observer.observe(el));

        const mobileBtn = document.getElementById("mobile-menu-btn");
        const mobileMenu = document.getElementById("mobile-menu");
        const hamIcon = document.getElementById("hamburger-icon");
        const closeIcon = document.getElementById("close-icon");

        mobileBtn?.addEventListener("click", () => {
          const open = !mobileMenu?.classList.contains("hidden");
          mobileMenu?.classList.toggle("hidden", open);
          hamIcon?.classList.toggle("hidden", !open);
          closeIcon?.classList.toggle("hidden", open);
        });

        mobileMenu?.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            mobileMenu?.classList.add("hidden");
            hamIcon?.classList.remove("hidden");
            closeIcon?.classList.add("hidden");
          });
        });

        window.addEventListener("scroll", handleNavbarScroll, {
          passive: true,
        });
        handleNavbarScroll();

        const savedTheme = localStorage.getItem("theme") || "dark";
        applyTheme(savedTheme);
        document
          .getElementById("theme-toggle")
          ?.addEventListener("click", () => {
            const current =
              document.documentElement.getAttribute("data-theme") || "dark";
            applyTheme(current === "dark" ? "light" : "dark");
          });

        const savedLang = localStorage.getItem("language") || "es";
        applyLanguage(savedLang);

        document.querySelectorAll("[data-lang-btn]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const lang = (btn as HTMLButtonElement).dataset.langBtn || "es";
            applyLanguage(lang);
          });
        });
      });
    </script>
  </body>
</html>
