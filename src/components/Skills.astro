<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          document.querySelectorAll(".skill-fill[data-w]").forEach((el) => {
            (el as HTMLElement).style.width =
              (el as HTMLElement).dataset.w + "%";
          });
          obs.disconnect();
        }
      });
    },
    { threshold: 0.25 },
  );

  const first = document.querySelector(".cat-panel");
  if (first) obs.observe(first);
</script>
