<style>
  .section-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .gradient-text {
    background: linear-gradient(
      135deg,
      var(--text-primary) 0%,
      var(--accent) 50%,
      var(--blue) 100%
    );
    background-size: 200% auto;
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradient-shift 5s ease infinite;
    display: inline-block;
  }
  @keyframes gradient-shift {
    0%,
    100% {
      background-position: 0%;
    }
    50% {
      background-position: 100%;
    }
  }

  .panel {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition:
      border-color 0.3s,
      box-shadow 0.3s;
  }
  .panel:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 20px var(--shadow-accent);
  }

  .panel-terminal {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition:
      border-color 0.3s,
      box-shadow 0.3s;
  }
  .panel-terminal:hover {
    border-color: var(--border-accent);
    box-shadow: 0 0 20px var(--shadow-accent);
  }
  .panel-terminal::before,
  .panel-terminal-top-bar {
    content: "";
    display: block;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), var(--blue), transparent);
  }
  .panel-terminal-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    background: var(--bg-panel);
  }
  .terminal-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .terminal-dot-red {
    background: #ff5f57;
  }
  .terminal-dot-yellow {
    background: #febc2e;
  }
  .terminal-dot-green {
    background: #28c840;
  }

  .what-card {
    transition:
      border-color 0.2s,
      box-shadow 0.2s,
      transform 0.2s;
  }
  .what-card:hover {
    border-color: var(--border-accent) !important;
    box-shadow: 0 8px 24px var(--shadow-accent);
    transform: translateY(-2px);
  }
  .what-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-sm);
    background: var(--bg-panel);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stat-panel {
    transition:
      border-color 0.2s,
      box-shadow 0.2s;
  }
  .stat-panel:hover {
    border-color: var(--border-accent) !important;
    box-shadow: 0 0 20px var(--shadow-accent);
  }

  .counter {
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
  }

  .status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 8px var(--accent);
    animation: pulse-dot 2s ease infinite;
    flex-shrink: 0;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      box-shadow: 0 0 8px var(--accent);
    }
    50% {
      box-shadow: 0 0 20px var(--accent);
    }
  }

  .timeline {
    position: relative;
    padding-left: 24px;
  }

  .timeline-item {
    position: relative;
    margin-bottom: 20px;
  }

  .timeline-dot {
    position: absolute;
    left: -27px;
    top: 20px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--bg-panel);
    border: 2px solid var(--border);
    transition: all 0.3s;
  }
  .timeline-dot--active {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
  }
  .timeline-dot--edu {
    background: var(--blue-dim);
    border-color: var(--blue);
  }

  .timeline::before {
    content: "";
    position: absolute;
    left: -22px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item:last-child .timeline-connector {
    display: none;
  }

  .timeline-badge {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--bg-panel);
  }

  .timeline-bullet {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.5;
  }
  .timeline-bullet::before {
    content: "→";
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 11px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--bg-panel);
    color: var(--text-secondary);
    transition: all 0.2s;
  }
  .badge:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  .learning-badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-accent);
    background: var(--accent-dim);
    color: var(--accent);
    transition: all 0.2s;
  }
  .learning-badge:hover {
    box-shadow: 0 0 12px var(--accent-glow);
  }

  .font-mono {
    font-family: var(--font-mono);
  }
  .font-display {
    font-family: var(--font-display);
  }
</style>

<script>
  function animateCounters() {
    document.querySelectorAll(".counter[data-target]").forEach((el) => {
      const target = parseInt((el as HTMLElement).dataset.target || "0", 10);
      const suffix = (el as HTMLElement).dataset.suffix || "+";
      let current = 0;
      const duration = 1200;
      const step = Math.ceil(duration / (target * 16));

      const timer = setInterval(() => {
        current++;
        el.textContent = current + suffix;
        if (current >= target) {
          el.textContent = target + suffix;
          clearInterval(timer);
        }
      }, step);
    });
  }

  const statsSection = document.querySelector(".stat-panel");
  if (statsSection) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animateCounters();
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 },
    );
    observer.observe(statsSection);
  }
</script>
