<script>
  (function initRain() {
    const canvas = document.getElementById("rain-canvas") as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext("2d")!;

    const chars =
      "アイウエオカキクケコ01{}[]<>/=;:() angular typescript node nest sql";
    const charArr = chars.split("");
    const fontSize = 12;
    let cols: number[] = [];
    let drops: number[] = [];

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      cols = [];
      drops = [];
      const numCols = Math.floor(canvas.width / (fontSize * 1.6));
      for (let i = 0; i < numCols; i++) {
        drops[i] = Math.random() * -50;
      }
    }

    function getAccentColor() {
      return (
        getComputedStyle(document.documentElement)
          .getPropertyValue("--accent")
          .trim() || "#00e87a"
      );
    }

    function draw() {
      ctx.fillStyle = "rgba(7, 8, 13, 0.05)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = `${fontSize}px 'JetBrains Mono', monospace`;

      const accent = getAccentColor();

      for (let i = 0; i < drops.length; i++) {
        const char = charArr[Math.floor(Math.random() * charArr.length)];
        const x = i * fontSize * 1.6;
        const y = drops[i] * fontSize;

        const alpha = Math.random() > 0.95 ? 1 : 0.3 + Math.random() * 0.3;
        ctx.fillStyle = accent.startsWith("#")
          ? accent +
            Math.floor(alpha * 255)
              .toString(16)
              .padStart(2, "0")
          : accent;

        ctx.fillText(char, x, y);

        if (y > canvas.height && Math.random() > 0.975) {
          drops[i] = 0;
        }
        drops[i] += 0.4;
      }
    }

    resize();
    window.addEventListener("resize", resize);
    setInterval(draw, 50);
  })();

  (function initTypewriter() {
    const el = document.getElementById("typewriter");
    if (!el) return;

    const phrasesEs = [
      "Full-Stack Developer",
      "Angular Specialist",
      "Node.js Backend Dev",
      "UI Architecture Nerd",
      "SaaS Builder",
    ];
    const phrasesEn = [
      "Full-Stack Developer",
      "Angular Specialist",
      "Node.js Backend Dev",
      "UI Architecture Nerd",
      "SaaS Builder",
    ];

    function getLang() {
      return document.documentElement.getAttribute("data-language") || "es";
    }

    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;
    let paused = false;

    function getPhrases() {
      return getLang() === "en" ? phrasesEn : phrasesEs;
    }

    function tick() {
      if (paused) return;
      const phrases = getPhrases();
      const current = phrases[phraseIndex];

      if (!deleting) {
        charIndex++;
        el!.textContent = current.slice(0, charIndex);
        if (charIndex === current.length) {
          paused = true;
          setTimeout(() => {
            paused = false;
            deleting = true;
          }, 2200);
        }
      } else {
        charIndex--;
        el!.textContent = current.slice(0, charIndex);
        if (charIndex === 0) {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
          paused = true;
          setTimeout(() => {
            paused = false;
          }, 400);
        }
      }

      const speed = deleting ? 40 : 75;
      setTimeout(tick, speed);
    }

    setTimeout(tick, 800);
  })();
</script>
